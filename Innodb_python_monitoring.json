            {
                "uuid": "c28f9c7874cc4843ae601d074d80e1ee",
                "template": "MySQL InnoDB Cluster by Python",
                "name": "MySQL InnoDB Cluster by Python",
                "description": "This template is used for monitoring a MySQL InnoDB Cluster.\nThe script is written in Python and located in the path /usr/lib/zabbix/externalscripts.\nIt operates in two modes:\n\n- Value mode: retrieves specific data when the input is value.\n\n- Discovery mode: performs auto-discovery when the input is discovery.\n\nIn the macro section, you must define the list of cluster nodes in the format [node1, node2, ...].\nAt least one reachable node is required.\nYou must also provide a valid username and password for database access in the macro configuration.\n\nMonitoring logs are stored in the directory:\n/var/log/zabbix/MysqlInnodb\n\nTo avoid conflicts with the mysqlsh command logs, the Python script automatically sets the mysqlsh execution log path in the environment to:\n/var/log/zabbix/MysqlInnodb/mysqlsh",
                "vendor": {
                    "name": "P&C",
                    "version": "1.0.0"
                },
                "groups": [
                    {
                        "name": "P&C Templates"
                    },
                    {
                        "name": "Templates / MySQL"
                    }
                ],
                "items": [
                    {
                        "uuid": "093dbdc6819b4d7e8fb94b2cdcf1afc3",
                        "name": "Cluster Errors",
                        "type": "DEPENDENT",
                        "key": "clusterErrors",
                        "value_type": "TEXT",
                        "preprocessing": [
                            {
                                "type": "JSONPATH",
                                "parameters": [
                                    "$.defaultReplicaSet.clusterErrors[0]"
                                ]
                            },
                            {
                                "type": "CHECK_JSON_ERROR",
                                "parameters": [
                                    "$.defaultReplicaSet.clusterErrors[0]"
                                ],
                                "error_handler": "CUSTOM_ERROR",
                                "error_handler_params": "The cluster data did not show any errors Field"
                            }
                        ],
                        "master_item": {
                            "key": "InnoDB_Cluster_Monitoring.py[value,{$USERNAME},{$PASSWORD},{$MEMBERSLIST},{HOST.NAME}]"
                        },
                        "tags": [
                            {
                                "tag": "Type",
                                "value": "Cluster"
                            }
                        ]
                    },
                    {
                        "uuid": "996cad08ee184946b98782a12f182e1d",

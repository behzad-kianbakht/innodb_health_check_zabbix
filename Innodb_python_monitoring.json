                                "expression": "last(/MySQL InnoDB Cluster by Python/clusterName,#1)<>last(/MySQL InnoDB Cluster by Python/clusterName,#2)",
                                "recovery_mode": "RECOVERY_EXPRESSION",
                                "recovery_expression": "last(/MySQL InnoDB Cluster by Python/clusterName,#1)=last(/MySQL InnoDB Cluster by Python/clusterName,#2)",
                                "name": "Cluster Primary Node Has been Changed",
